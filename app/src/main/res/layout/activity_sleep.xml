<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingTop="88dp"
        android:paddingBottom="40dp">

        <!-- Header -->
        <TextView
            android:text="Sleep Check-in"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="32sp"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:text="How did you sleep last night?"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="40dp"/>

        <!-- Hours card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:text="HOURS SLEPT"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_marginBottom="16dp"/>

                <!-- +/- picker row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnHoursMinus"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="−"
                        android:textSize="22sp"
                        app:backgroundTint="?attr/colorSurface"
                        app:strokeColor="?attr/colorPrimary"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="24dp"
                        android:textColor="?attr/colorPrimary"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"/>

                    <LinearLayout
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvHoursDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="7.5"
                            android:textSize="56sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorPrimary"
                            android:gravity="center"/>

                        <TextView
                            android:text="hours"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="?android:attr/textColorSecondary"
                            android:gravity="center"/>

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnHoursPlus"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="+"
                        android:textSize="22sp"
                        app:backgroundTint="?attr/colorPrimary"
                        app:cornerRadius="24dp"
                        android:textColor="?attr/colorOnPrimary"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"/>

                </LinearLayout>

                <!-- hidden EditText to keep save logic working -->
                <EditText
                    android:id="@+id/etHours"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone"
                    android:inputType="numberDecimal"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Energy card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:text="MORNING ENERGY"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_marginBottom="16dp"/>

                <!-- 5 emoji energy buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="5">

                    <LinearLayout
                        android:id="@+id/btnEnergy1"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/energy_btn_bg"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:text="😴" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="22sp"/>
                        <TextView android:text="1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:textColor="?android:attr/textColorSecondary"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnEnergy2"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/energy_btn_bg"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:text="😕" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="22sp"/>
                        <TextView android:text="2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:textColor="?android:attr/textColorSecondary"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnEnergy3"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/energy_btn_bg"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:text="😐" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="22sp"/>
                        <TextView android:text="3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:textColor="?android:attr/textColorSecondary"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnEnergy4"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/energy_btn_bg"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:text="🙂" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="22sp"/>
                        <TextView android:text="4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:textColor="?android:attr/textColorSecondary"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnEnergy5"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/energy_btn_bg"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:text="⚡" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="22sp"/>
                        <TextView android:text="5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:textColor="?android:attr/textColorSecondary"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- hidden seekbar to keep save logic working -->
                <SeekBar
                    android:id="@+id/seekEnergy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="4"
                    android:progress="2"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvEnergyLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:visibility="gone"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Save button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveSleep"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Sleep Log"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            app:backgroundTint="?attr/colorPrimary"
            app:cornerRadius="16dp"
            app:rippleColor="?attr/colorOnPrimary"/>

        <!-- Last 7 nights card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:text="LAST 7 NIGHTS"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:textColor="?android:attr/textColorSecondary"/>

                    <TextView
                        android:id="@+id/tvAvgSleep"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="?attr/colorPrimary"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llSleepHistory"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:orientation="horizontal"
                    android:gravity="bottom|center_horizontal"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Tip card with colored background -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorPrimaryContainer"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:text="💡"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tvSleepTip"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Most habit completions happen after 7+ hours of sleep."
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:lineSpacingExtra="3dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>