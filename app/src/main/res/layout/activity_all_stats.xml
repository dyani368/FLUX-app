<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground">

    <!-- header -->
    <TextView
        android:text="HISTORY"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="32sp"
        android:textColor="?attr/colorOnSurface"
        android:textStyle="bold"
        android:paddingStart="24dp"
        android:paddingTop="52dp"
        android:paddingBottom="20dp"/>

    <!-- tab row -->
    <LinearLayout
        android:id="@+id/tabRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="20dp">

        <TextView
            android:id="@+id/tabCalendar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calendar"
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            android:paddingBottom="8dp"
            android:layout_marginEnd="24dp"/>

        <TextView
            android:id="@+id/tabAllHabits"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All Habits"
            android:textSize="16sp"
            android:textColor="?android:attr/textColorSecondary"
            android:paddingBottom="8dp"
            android:layout_marginEnd="24dp"/>

        <TextView
            android:id="@+id/tabAchievements"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Achievements"
            android:textSize="16sp"
            android:textColor="?android:attr/textColorSecondary"
            android:paddingBottom="8dp"/>

    </LinearLayout>

    <!-- stat cards row -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="150dp"
            android:orientation="horizontal">

            <!-- streak card -->
            <LinearLayout
                android:layout_width="140dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@drawable/stat_card_blue"
                android:padding="16dp"
                android:layout_marginEnd="12dp">

                <TextView
                    android:text="CURRENT\nSTREAK"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvCurrentStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="0"
                    android:textSize="52sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvBestStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Best Streak: 0"
                    android:textSize="11sp"
                    android:textColor="#AAAAFF"/>

            </LinearLayout>

            <!-- completions card -->
            <LinearLayout
                android:layout_width="140dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@drawable/stat_card_red"
                android:padding="16dp"
                android:layout_marginEnd="12dp">

                <TextView
                    android:text="HABIT\nFINISHED"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvHabitsFinished"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="0"
                    android:textSize="52sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvFinishedWeek"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This week: 0"
                    android:textSize="11sp"
                    android:textColor="#FFAAAA"/>

            </LinearLayout>

            <!-- completion rate card -->
            <LinearLayout
                android:layout_width="140dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@drawable/stat_card_yellow"
                android:padding="16dp">

                <TextView
                    android:text="COMPLETION\nRATE"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvCompletionRate"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="0%"
                    android:textSize="52sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvRateHabits"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/0 habits"
                    android:textSize="11sp"
                    android:textColor="#FFFFAA"/>

            </LinearLayout>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- tab content -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- calendar tab -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/contentCalendar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardCornerRadius="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvMonthYear"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="March 2026"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:layout_marginBottom="12dp"/>

                        <!-- day headers -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">

                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="SUN" android:textSize="10sp" android:textColor="?android:attr/textColorSecondary" android:gravity="center"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="MON" android:textSize="10sp" android:textColor="?android:attr/textColorSecondary" android:gravity="center"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="TUE" android:textSize="10sp" android:textColor="?android:attr/textColorSecondary" android:gravity="center"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="WED" android:textSize="10sp" android:textColor="?android:attr/textColorSecondary" android:gravity="center"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="THU" android:textSize="10sp" android:textColor="?android:attr/textColorSecondary" android:gravity="center"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="FRI" android:textSize="10sp" android:textColor="?android:attr/textColorSecondary" android:gravity="center"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="SAT" android:textSize="10sp" android:textColor="?android:attr/textColorSecondary" android:gravity="center"/>

                        </LinearLayout>

                        <com.example.flux.ui.dashboard.HeatmapView
                            android:id="@+id/heatmapView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- all habits tab -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAllStats"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="8dp"
            android:clipToPadding="false"
            android:visibility="gone"/>

        <!-- achievements tab -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/contentAchievements"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvBestHabitLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🏆  Most Consistent Habit"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvBestHabit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="24sp"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold"
                    android:layout_marginBottom="24dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔥  Longest Streak"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvLongestStreak"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0 days"
                    android:textSize="24sp"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold"
                    android:layout_marginBottom="24dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💤  Average Sleep"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvAvgSleep"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="— hrs"
                    android:textSize="24sp"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold"/>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </FrameLayout>

</LinearLayout>
